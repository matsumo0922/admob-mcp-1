{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "mkdir -p public",
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 60
    },
    "api/setup.ts": {
      "maxDuration": 10
    },
    "api/oauth/callback.ts": {
      "maxDuration": 10
    },
    "api/oauth/authorize.ts": {
      "maxDuration": 10
    },
    "api/oauth/token.ts": {
      "maxDuration": 10
    },
    "api/oauth/register.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/.well-known/oauth-protected-resource",
      "destination": "/api/well-known/oauth-protected-resource"
    },
    {
      "source": "/.well-known/oauth-authorization-server",
      "destination": "/api/well-known/oauth-authorization-server"
    },
    {
      "source": "/oauth/register",
      "destination": "/api/oauth/register"
    },
    {
      "source": "/oauth/authorize",
      "destination": "/api/oauth/authorize"
    },
    {
      "source": "/oauth/token",
      "destination": "/api/oauth/token"
    }
  ]
}
